{
    "name": "findadoc-mcp",
    "version": "0.1.0",
    "description": "Find a Doc MCP Server",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "dev": "tsx watch src/index.ts",
        "dev:http": "tsx watch src/http.ts",
        "start": "node dist/index.js",
        "start:http": "node dist/http.js",
        "lint": "ESLINT_USE_FLAT_CONFIG=true eslint .",
        "lint:fix": "ESLINT_USE_FLAT_CONFIG=true eslint . --fix",
        "lint:ci": "ESLINT_USE_FLAT_CONFIG=true eslint .",
        "test": "vitest run",
        "test:watch": "vitest",
        "prepare": "husky"
    },
    "keywords": [
        "mcp",
        "findadoc",
        "healthcare",
        "japan"
    ],
    "license": "BSD-3-Clause",
    "engines": {
        "node": ">=22.12.0"
    },
    "packageManager": "yarn@4.3.1",
    "dependencies": {
        "@fastify/rate-limit": "^10.3.0",
        "@modelcontextprotocol/sdk": "^1.0.0",
        "fastify": "^5.8.2",
        "graphql": "^16.13.1",
        "graphql-request": "^7.4.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@stylistic/eslint-plugin": "^2.0.0",
        "@types/node": "^25.5.0",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "eslint": "^9.0.0",
        "globals": "^15.0.0",
        "husky": "^9.0.0",
        "tsx": "^4.0.0",
        "typescript": "^5.0.0",
        "vitest": "^2.0.0"
    }
}
